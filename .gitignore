# ══════════════════════════════════════
# .gitignore — Mapa Político
# Entorno: PHP vanilla + JS (ES6+)
# ══════════════════════════════════════

# ── PHP ────────────────────────────────
*.log
/vendor/
composer.lock

# ── Variables de entorno ────────────────
.env
.env.local
.env.*.local

# ── Node / npm (si se usa para build tools)
node_modules/
npm-debug.log*
yarn-error.log

# ── Editores e IDEs ────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.DS_Store
Thumbs.db

# ── Caché y temporales ─────────────────
/cache/
/tmp/
*.tmp
*.bak
*.orig

# ── Sass / Build outputs ───────────────
/dist/
*.css.map
*.js.map

# ── Configuración de servidor local ───
/config/local.php
/config/*.local.php
